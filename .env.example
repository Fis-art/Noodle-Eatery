# ============================================
# Toko Online - Environment Variables
# Copy file ini ke .env lalu sesuaikan nilainya
# ============================================

# Port server (ganti jika port sudah terpakai)
PORT=3000

# Admin credentials
ADMIN_USER=admin
ADMIN_PASSWORD=your-password-here

# Session secret (ganti untuk keamanan production)
SESSION_SECRET=your-secret-key-here

# Informasi Toko
STORE_NAME=Nama Toko Anda
STORE_ADDRESS=Jl. Contoh No. 123, Kota, Provinsi
STORE_PHONE=0812-3456-7890
STORE_HOURS=08:00 - 21:00
STORE_DESCRIPTION=Deskripsi singkat tentang toko Anda

# Social Media URLs
FACEBOOK_URL=https://www.facebook.com/
INSTAGRAM_URL=https://www.instagram.com/
TIKTOK_URL=https://www.tiktok.com/@
